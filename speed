	setupServerAntiAfk()
	setupCharacterHooks()

	local hadLegendaryRod = getRod() ~= nil
	local rodMissingSince = nil
	_G.AutoFishRodConnection = RunService.Heartbeat:Connect(function()
		if _G.AutoFishRejoining or not _G.AutoFishEnabled or _G.AutoFishCeremony then return end
		local rod = getRod()
		if rod then
			hadLegendaryRod = true
			rodMissingSince = nil
			return
		end
		if not hadLegendaryRod then return end
		if _G.AutoFishBusy or _G.AutoFishReturning or _G.AutoFishReturnWait then return end
		if not rodMissingSince then
			rodMissingSince = tick()
		elseif tick() - rodMissingSince >= ROD_MISSING_REJOIN_SEC then
			rodMissingSince = nil
			_G.AutoFishPendingReturn = true
			_G.AutoFishMode = "Legendary rod missing — rejoining"
			_G.AutoFishRejoin(true)
		end
	end)

	if _G.AutoFishPendingReturn then
		_G.AutoFishPendingReturn = false
		_G.AutoFishPersistState(false)
		task.defer(function()
			local char = LocalPlayer.Character
			if not char then
				char = LocalPlayer.CharacterAdded:Wait()
			end
			char:WaitForChild("HumanoidRootPart", 20)
			task.wait(0.5)
			returnToDock()
		end)
	end

	pcall(function()
		_G.AutoFishPersistState(false)
	end)

	_G.AutoFishHeartbeat = RunService.Heartbeat:Connect(function()
		if not _G.AutoFishEnabled or _G.AutoFishBusy or _G.AutoFishReturning or _G.AutoFishReturnWait or _G.AutoFishSetCastMode or _G.AutoFishCeremony then return end
		if countFish() >= MAX_FISH then
			task.spawn(runSellTrip)
			return
		end
		local tool = getRod()
		if not tool then return end
		if tool.Parent == LocalPlayer.Backpack then
			equipRod(tool)
			return
		end
		trackState(tool)
		local state = getState(tool)
		local now = tick()
		if state == "Idle" then
			if now - _G.AutoFishTimers.lastCast >= CAST_COOLDOWN and castRod(tool) then
				_G.AutoFishStats.casts += 1
				_G.AutoFishTimers.lastCast = now
			end
		elseif state == "QTE" then
			if now - _G.AutoFishTimers.lastReel >= getReelCooldown(tool) and shouldReel(tool) then
				tool:Activate()
				_G.AutoFishStats.reels += 1
				_G.AutoFishTimers.lastReel = now
			end
		end
	end)

	_G.AutoFishGuiHeartbeat = RunService.Heartbeat:Connect(function()
		refreshGui()
	end)

	task.defer(function()
		if not _G.AutoFishFlagSpot then
			_G.AutoFishFlagSpot = { position = getFlagPos(), setAt = os.clock() }
		end
	end)

	local ceremonyLastTrigger = 0
	local function tryStartCeremony()
		if _G.AutoFishCeremony then return end
		if _G.AutoFishBusy and not _G.AutoFishReturning and not _G.AutoFishReturnWait then return end
		local now = tick()
		if now - ceremonyLastTrigger < 8 then return end
		ceremonyLastTrigger = now
		task.spawn(runCeremony)
	end
	_G.AutoFishTryStartCeremony = tryStartCeremony

	local anthem = getAnthemSound()
	if anthem then
		_G.AutoFishCeremonyConnection = anthem:GetPropertyChangedSignal("IsPlaying"):Connect(function()
			if anthem.IsPlaying then tryStartCeremony() end
		end)
		_G.AutoFishCeremonyPlayedConnection = anthem.Played:Connect(tryStartCeremony)
	end

	print("[AutoFish v8.4] Rejoin via " .. AUTOFISH_SCRIPT_URL)
end

