	startReturnDeathWait = function()
		if not _G.AutoFishEnabled or _G.AutoFishReturnOnDeath == false then return end
		_G.AutoFishReturnWaitToken += 1
		local token = _G.AutoFishReturnWaitToken
		_G.AutoFishReturnToken += 1
		_G.AutoFishReturnWait = true
		_G.AutoFishReturning = false
		_G.AutoFishBusy = true
		stowTools()

		local waitSec = math.random(RETURN_DEATH_WAIT_MIN, RETURN_DEATH_WAIT_MAX)
		local endTime = tick() + waitSec
		_G.AutoFishReturnWaitUntil = endTime
		_G.AutoFishMode = "Waiting after death"

		local function finishWait()
			if token ~= _G.AutoFishReturnWaitToken then return end
			_G.AutoFishReturnWait = false
			destroyReturnWaitGui()
			if _G.AutoFishReturnWaitHoldConnection then
				pcall(function() _G.AutoFishReturnWaitHoldConnection:Disconnect() end)
				_G.AutoFishReturnWaitHoldConnection = nil
