	local function setupCharacterHooks()
		local pendingRespawnReturn = false
		local pendingDeathDuringReturn = false
		local function hookCharacter(char)
			local hum = char:WaitForChild("Humanoid", 15)
			if hum then
				hum.Died:Connect(function()
					if _G.AutoFishReturning or _G.AutoFishReturnWait then
						pendingDeathDuringReturn = true
						_G.AutoFishReturnToken += 1
						if _G.AutoFishReturnWait then
							_G.AutoFishReturnWaitToken += 1
							_G.AutoFishReturnWait = false
							if destroyReturnWaitGui then destroyReturnWaitGui() end
							if _G.AutoFishReturnWaitHoldConnection then
								pcall(function() _G.AutoFishReturnWaitHoldConnection:Disconnect() end)
								_G.AutoFishReturnWaitHoldConnection = nil
							end
						end
					elseif _G.AutoFishEnabled and _G.AutoFishReturnOnDeath ~= false then
						pendingRespawnReturn = true
					end
				end)
			end
			if pendingDeathDuringReturn then
				pendingDeathDuringReturn = false
				task.spawn(function()
					char:WaitForChild("HumanoidRootPart", 15)
					task.wait(0.35)
					if startReturnDeathWait then startReturnDeathWait() end
				end)
			elseif pendingRespawnReturn then
				pendingRespawnReturn = false
				task.spawn(function()
					char:WaitForChild("HumanoidRootPart", 15)
					task.wait(0.35)
					returnToDock()
				end)
			end
		end
		if _G.AutoFishCharacterConnection then
			pcall(function() _G.AutoFishCharacterConnection:Disconnect() end)
		end
		_G.AutoFishCharacterConnection = LocalPlayer.CharacterAdded:Connect(function(char)
			task.defer(function()
				hookCharacter(char)
			end)
		end)
		if LocalPlayer.Character then
			task.defer(function()
				hookCharacter(LocalPlayer.Character)
			end)
		end
	end
	local function runSellTrip()
		if _G.AutoFishBusy then return end
		_G.AutoFishBusy = true
		stowTools()
		_G.AutoFishMode = "Walking to sell"
		walkTo(getSellPos(), 60)
		sellAllFish()
		_G.AutoFishMode = "Walking to dock"
		walkTo(getDockPos(), 120)
		faceLook(getDockLook())
		local rod = getRod()
		if rod then equipRod(rod) end
		_G.AutoFishMode = "Fishing"
		_G.AutoFishBusy = false
	end
	local function trackState(tool)
		local state = getState(tool)
		if state ~= _G.AutoFishStats.lastState then
			if state == "Success" then _G.AutoFishStats.catches += 1 end
			if state == "Fail" then _G.AutoFishStats.fails += 1 end
			_G.AutoFishStats.lastState = state
		end
	end

