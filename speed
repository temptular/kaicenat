	}

	local function getDockPos()
		if _G.AutoFishDockSpot and _G.AutoFishDockSpot.position then return _G.AutoFishDockSpot.position end
		return Vector3.new(1839.941650390625, 272.7584533691406, 552.4816284179688)
	end
	local function getDockLook()
		if _G.AutoFishDockSpot and _G.AutoFishDockSpot.lookVector then return _G.AutoFishDockSpot.lookVector end
		return Vector3.new(-0.7151891589164734, 0, -0.6989309787750244)
	end
	local function getSellPrompt()
		if _G.AutoFishSellSpot and _G.AutoFishSellSpot.prompt and _G.AutoFishSellSpot.prompt.Parent then
			return _G.AutoFishSellSpot.prompt
		end
		local dockPos = getDockPos()
		local bestPrompt, bestDist
		for _, inst in ipairs(workspace:GetDescendants()) do
			if inst:IsA("ProximityPrompt") and inst.ActionText == "Sell Fish" then
				local parent = inst.Parent
				local npcPos = parent and parent:IsA("BasePart") and parent.Position
				if npcPos then
					local flat = Vector3.new(npcPos.X - dockPos.X, 0, npcPos.Z - dockPos.Z)
					if not bestDist or flat.Magnitude < bestDist then
						bestPrompt, bestDist = inst, flat.Magnitude
					end
				end
			end
		end
		return bestPrompt
	end
	local function getSellPos()
		if _G.AutoFishSellSpot and _G.AutoFishSellSpot.position then return _G.AutoFishSellSpot.position end
		local prompt = getSellPrompt()
		local sheenPos = prompt and prompt.Parent and prompt.Parent:IsA("BasePart") and prompt.Parent.Position
			or Vector3.new(1815.7200927734375, 246.65554809570312, 505.8079528808594)
		local dockPos = getDockPos()
		local flat = Vector3.new(dockPos.X - sheenPos.X, 0, dockPos.Z - sheenPos.Z)
		if flat.Magnitude > 0.1 then return sheenPos + flat.Unit * 5 end
		return sheenPos + Vector3.new(5, 0, 0)
	end
	local function getFlagPos()
		if _G.AutoFishFlagSpot and _G.AutoFishFlagSpot.position then return _G.AutoFishFlagSpot.position end
		return Vector3.new(1248.4837646484375, 90, -275.8426513671875)
	end
	local function countFish()
		local n = 0
		local function scan(p)
			if p then
				for _, c in ipairs(p:GetChildren()) do
					if c:IsA("Tool") and c:GetAttribute("FishType") then n += 1 end
				end
			end
		end
		scan(LocalPlayer.Backpack)
		scan(LocalPlayer.Character)
		return n
	end
	local function findRodIn(parent)
		return parent and parent:FindFirstChild(ROD_NAME)
	end
	local function getRod()
		local char = LocalPlayer.Character
		local rod = findRodIn(char)
		if rod then return rod end
		local f = workspace:FindFirstChild(LocalPlayer.Name)
		rod = findRodIn(f)
		if rod then return rod end
		return findRodIn(LocalPlayer.Backpack)
	end
	local function getNextFish()
		for _, c in ipairs(LocalPlayer.Backpack:GetChildren()) do
			if c:IsA("Tool") and c:GetAttribute("FishType") then return c end
		end
		local char = LocalPlayer.Character
		if char then
			for _, c in ipairs(char:GetChildren()) do
				if c:IsA("Tool") and c:GetAttribute("FishType") then return c end
			end
		end
	end
	local function getState(tool) return tool:GetAttribute("FishingState") or "Idle" end
	local function getFishingClient(tool)
		if not getgc then return end
		local remote = tool and tool:FindFirstChild("FishingInput")
		if not remote then return end
		for _, v in ipairs(getgc(true)) do
			if type(v) == "table" and rawget(v, "_inputRemote") and v._inputRemote == remote then return v end
		end
	end
	local function getBarPosition(tool)
		local client = getFishingClient(tool)
		if client and typeof(client._playerPosition) == "number" then return client._playerPosition end
		local g = PlayerGui:FindFirstChild("QuickTimeGui")
		if g and g.Enabled then
			local pf = g:FindFirstChild("MainFrame") and g.MainFrame:FindFirstChild("PlayerFrame")
			if pf then return pf.Position.X.Scale end
		end
	end
	local function getCastPoint()
		if _G.AutoFishCastSpot and _G.AutoFishCastSpot.position then return _G.AutoFishCastSpot.position end
		local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
		for _, inst in ipairs(workspace:GetChildren()) do
			if inst.Name == "FishingBobber" and inst:IsA("BasePart") and (inst.Position - hrp.Position).Magnitude <= 150 then
				return inst.Position
			end
		end
		local fwd = hrp.Position + hrp.CFrame.LookVector * 25
		return Vector3.new(fwd.X, WATER_Y, fwd.Z)
	end
	local function facePoint(pt)
		local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
		if hrp then hrp.CFrame = CFrame.new(hrp.Position, Vector3.new(pt.X, hrp.Position.Y, pt.Z)) end
	end
	local function faceLook(look)
		local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
		if hrp then hrp.CFrame = CFrame.new(hrp.Position, hrp.Position + look) end
	end
	local function clickScreenAtWorld(pt)
		local cam = workspace.CurrentCamera
		if not cam then return false end
		local screen, onScreen = cam:WorldToViewportPoint(pt)
		if not onScreen then return false end
		VirtualInputManager:SendMouseButtonEvent(screen.X, screen.Y, 0, true, game, 1)
		VirtualInputManager:SendMouseButtonEvent(screen.X, screen.Y, 0, false, game, 1)
		return true
	end
	local function castRod(tool)
		local pt = getCastPoint()
		if not pt then return false end
		facePoint(pt)
		task.wait(0.05)
		clickScreenAtWorld(pt)
		tool:Activate()
		return true
	end
	local function equipRod(tool)
		local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
		if hum and tool and tool.Parent == LocalPlayer.Backpack then hum:EquipTool(tool) end
	end
	local function stowTools()
		local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
		if hum then hum:UnequipTools() end
	end
	local function stopCeremonyFacing()
		if _G.AutoFishCeremonyFaceConn then
			pcall(function() _G.AutoFishCeremonyFaceConn:Disconnect() end)
			_G.AutoFishCeremonyFaceConn = nil
		end
		_G.AutoFishCeremonyMaintainFace = false
		local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
		if hum then
			if _G.AutoFishCeremonySavedAutoRotate ~= nil then
				hum.AutoRotate = _G.AutoFishCeremonySavedAutoRotate
			else
				hum.AutoRotate = true
			end
			_G.AutoFishCeremonySavedAutoRotate = nil
		end
	end
	local function applyCeremonyFace()
		local flagPos = getFlagPos()
		local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
		if hrp then
			hrp.CFrame = CFrame.new(hrp.Position, Vector3.new(flagPos.X, hrp.Position.Y, flagPos.Z))
		end
	end
	local function startCeremonyFacing()
		stopCeremonyFacing()
		local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
		local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
		if not hum or not hrp then return false end
		hum:MoveTo(hrp.Position)
		_G.AutoFishCeremonySavedAutoRotate = hum.AutoRotate
		hum.AutoRotate = false
		applyCeremonyFace()
		task.defer(applyCeremonyFace)
		return true
	end
	local function pressSaluteKey()
		VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.B, false, game)
		task.wait(0.05)
		VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.B, false, game)
	end
	local function getAnthemSound()
		return SoundService:FindFirstChild("HourlyStarSpangledBanner")
	end
	local function waitForAnthemEnd(token)
		local anthem = getAnthemSound()
		if not anthem then return end
		_G.AutoFishMode = "Ceremony: anthem"
		local deadline = tick() + math.max(anthem.TimeLength + 8, 90)
		while tick() < deadline do
			if token ~= _G.AutoFishCeremonyToken then return end
			if not anthem.IsPlaying then break end
			task.wait(0.25)
		end
	end
	local function finishCeremony(token)
		if token and token ~= _G.AutoFishCeremonyToken then return end
		stopCeremonyFacing()
		_G.AutoFishCeremony = false
		if not _G.AutoFishBusy then _G.AutoFishMode = "Fishing" end
		local rod = getRod()
		if rod and _G.AutoFishEnabled then equipRod(rod) end
	end
	local function runCeremony()
		if _G.AutoFishCeremony then return end
		if _G.AutoFishBusy and not _G.AutoFishReturning and not _G.AutoFishReturnWait then return end
		if _G.AutoFishReturning or _G.AutoFishReturnWait then
			_G.AutoFishReturnToken += 1
			_G.AutoFishReturning = false
			if _G.AutoFishReturnWait then
				_G.AutoFishReturnWaitToken += 1
				_G.AutoFishReturnWait = false
				if destroyReturnWaitGui then destroyReturnWaitGui() end
				if _G.AutoFishReturnWaitHoldConnection then
					pcall(function() _G.AutoFishReturnWaitHoldConnection:Disconnect() end)
					_G.AutoFishReturnWaitHoldConnection = nil
				end
			end
			_G.AutoFishBusy = false
		end
		_G.AutoFishCeremony = true
		_G.AutoFishCeremonyToken += 1
		local token = _G.AutoFishCeremonyToken
		local ok, err = pcall(function()
			_G.AutoFishMode = "Ceremony: unequip"
			stowTools()
			task.wait(CEREMONY_UNEQUIP_WAIT)
			if token ~= _G.AutoFishCeremonyToken then return end
			_G.AutoFishMode = "Ceremony: face flag"
			if not startCeremonyFacing() then
				error("Could not face flag")
			end
			task.wait(CEREMONY_FACE_WAIT)
			if token ~= _G.AutoFishCeremonyToken then return end
			_G.AutoFishMode = "Ceremony: saluting"
			pressSaluteKey()
			if token ~= _G.AutoFishCeremonyToken then return end
			waitForAnthemEnd(token)
		end)
		if not ok then
			warn("[AutoFish] Ceremony failed:", err)
			_G.AutoFishMode = "Ceremony failed"
		end
		finishCeremony(token)
	end
	_G.AutoFishRunCeremony = runCeremony
	_G.AutoFishFaceFlag = function()
		return startCeremonyFacing()
	end
	local function getReelCooldown(tool)
		return math.clamp((tonumber(tool:GetAttribute("ClickForce")) or 0.045) / (tonumber(tool:GetAttribute("DrainSpeed")) or 0.2), 0.18, 0.32)
	end
	local function shouldReel(tool)
		local pos = getBarPosition(tool)
		if pos == nil then return false end
		if pos >= SAFE_MAX then return false end
		if pos <= SAFE_MIN then return true end
		return pos < BAR_CENTER - 0.015
	end
	local PATH_AGENT = {
		AgentRadius = 2,
		AgentHeight = 5,
		AgentCanJump = true,
		AgentCanClimb = true,
		WaypointSpacing = 3,
	}
	local STUCK_DETECT_SEC, JUMP_BURST_SEC, PROGRESS_DIST = 3, 5, 1.2
	local JUMP_UP_THRESHOLD, JUMP_STUCK_SEC = 1.2, 1.2
	local function refreshWalkCharacter()
		local char = LocalPlayer.Character
		if not char then return nil, nil end
		return char:FindFirstChildOfClass("Humanoid"), char:FindFirstChild("HumanoidRootPart")
	end
	local function targetNeedsJump(movePos, hrp)
		if not hrp or not movePos then return false end
		return (movePos.Y - hrp.Position.Y) > JUMP_UP_THRESHOLD
	end
	local function attemptJump(hum)
		hum.Jump = true
		pcall(function()
			local state = hum:GetState()
			if state ~= Enum.HumanoidStateType.Jumping and state ~= Enum.HumanoidStateType.Freefall then
				hum:ChangeState(Enum.HumanoidStateType.Jumping)
			end
		end)
	end
	local function runJumpBurst(hum, hrp, movePos, segmentDeadline, aborted, lastProgressPos, lastProgressAt)
		local burstEnd = tick() + JUMP_BURST_SEC
		while tick() < burstEnd and tick() < segmentDeadline do
			if aborted() then return false, lastProgressPos, lastProgressAt end
			hum:MoveTo(movePos)
			attemptJump(hum)
			task.wait(0.08)
			hum, hrp = refreshWalkCharacter()
			if not hum or not hrp then return false, lastProgressPos, lastProgressAt end
			local moved = (hrp.Position - lastProgressPos).Magnitude
			if moved >= PROGRESS_DIST then
				lastProgressPos = hrp.Position
				lastProgressAt = tick()
			end
		end
		return true, lastProgressPos, tick()
	end
	local function waitWhileMoving(hum, hrp, movePos, segmentDeadline, aborted, lastProgressPos, lastProgressAt, arrivedFn, wpAction)
		while tick() < segmentDeadline do
			hum, hrp = refreshWalkCharacter()
			if not hum or not hrp then return false, lastProgressPos, lastProgressAt end
			if aborted() then return false, lastProgressPos, lastProgressAt end
			if arrivedFn and arrivedFn(hrp) then
				return true, lastProgressPos, lastProgressAt
			end
			hum:MoveTo(movePos)
			local goingUp = wpAction == Enum.PathWaypointAction.Jump or targetNeedsJump(movePos, hrp)
			if goingUp then
				attemptJump(hum)
			end
			local moved = (hrp.Position - lastProgressPos).Magnitude
			if moved >= PROGRESS_DIST then
				lastProgressPos = hrp.Position
				lastProgressAt = tick()
			else
				local stuckFor = tick() - lastProgressAt
				local stuckLimit = goingUp and JUMP_STUCK_SEC or STUCK_DETECT_SEC
				if stuckFor >= stuckLimit then
					local ok
					ok, lastProgressPos, lastProgressAt = runJumpBurst(hum, hrp, movePos, segmentDeadline, aborted, lastProgressPos, lastProgressAt)
					if not ok then return false, lastProgressPos, lastProgressAt end
				end
			end
			task.wait(goingUp and 0.08 or 0.12)
		end
		hum, hrp = refreshWalkCharacter()
		if hum and hrp and arrivedFn and arrivedFn(hrp) then
			return true, lastProgressPos, lastProgressAt
		end
		return nil, lastProgressPos, lastProgressAt
	end
	local function nearPos(a, b, flatRange, yRange)
		flatRange = flatRange or 5
		yRange = yRange or 14
		local flat = Vector3.new(a.X - b.X, 0, a.Z - b.Z)
		return flat.Magnitude <= flatRange and math.abs(a.Y - b.Y) <= yRange
	end
	local function walkTo(targetPos, timeout, shouldContinue)
		timeout = timeout or 45
		local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
		local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
		if not hum or not hrp then return false end

		local function aborted()
			if shouldContinue and not shouldContinue() then
				hum:MoveTo(hrp.Position)
				return true
			end
			return false
		end

		if nearPos(hrp.Position, targetPos) then
			hum:MoveTo(hrp.Position)
			return true
		end

		local deadline = tick() + timeout
		local lastProgressPos = hrp.Position
		local lastProgressAt = tick()

		while tick() < deadline do
			hum, hrp = refreshWalkCharacter()
			if not hum or not hrp then return false end
			if aborted() then return false end
			if _G.AutoFishTryStartCeremony then
				local anthem = SoundService:FindFirstChild("HourlyStarSpangledBanner")
				if anthem and anthem.IsPlaying and not _G.AutoFishCeremony then
					_G.AutoFishTryStartCeremony()
				end
			end
			if nearPos(hrp.Position, targetPos) then
				hum:MoveTo(hrp.Position)
				return true
			end

			local path = PathfindingService:CreatePath(PATH_AGENT)
			local computeOk = pcall(function()
				path:ComputeAsync(hrp.Position, targetPos)
			end)
			local status = computeOk and path.Status or nil
			if status ~= Enum.PathStatus.Success and status ~= Enum.PathStatus.ClosestNoPath then
				hum:MoveTo(targetPos)
				local segEnd = tick() + 10
				local ok
				ok, lastProgressPos, lastProgressAt = waitWhileMoving(hum, hrp, targetPos, segEnd, aborted, lastProgressPos, lastProgressAt, function(root)
					return nearPos(root.Position, targetPos)
				end, targetNeedsJump(targetPos, hrp) and Enum.PathWaypointAction.Jump or nil)
				if ok == false then return false end
				if ok and nearPos(hrp.Position, targetPos) then
					hum:MoveTo(hrp.Position)
					return true
				end
			else
				local waypoints = path:GetWaypoints()
				if #waypoints <= 1 then
					hum:MoveTo(targetPos)
					local segEnd = tick() + 10
					local ok
					ok, lastProgressPos, lastProgressAt = waitWhileMoving(hum, hrp, targetPos, segEnd, aborted, lastProgressPos, lastProgressAt, function(root)
						return nearPos(root.Position, targetPos)
					end, targetNeedsJump(targetPos, hrp) and Enum.PathWaypointAction.Jump or nil)
					if ok == false then return false end
				else
					for wpIndex = 2, #waypoints do
						if aborted() then return false end
						if tick() >= deadline then break end
						if nearPos(hrp.Position, targetPos) then
							hum:MoveTo(hrp.Position)
							return true
						end

						local wp = waypoints[wpIndex]
						local mustJump = wp.Action == Enum.PathWaypointAction.Jump
							or targetNeedsJump(wp.Position, hrp)
						if mustJump then
							attemptJump(hum)
						end
						hum:MoveTo(wp.Position)

						local wpDeadline = tick() + 10
						local ok
						ok, lastProgressPos, lastProgressAt = waitWhileMoving(hum, hrp, wp.Position, wpDeadline, aborted, lastProgressPos, lastProgressAt, function(root)
							return nearPos(root.Position, wp.Position, 4, 10) or nearPos(root.Position, targetPos)
						end, wp.Action)
						if ok == false then return false end
						if nearPos(hrp.Position, targetPos) then
							hum:MoveTo(hrp.Position)
							return true
						end
					end
				end
			end

			if nearPos(hrp.Position, targetPos, 8, 16) then
				hum:MoveTo(hrp.Position)
				return true
			end
			task.wait(0.15)
		end

		if aborted() then return false end
		return nearPos(hrp.Position, targetPos, 8, 16)
	end
	local function sellHeldFish()
		local prompt = getSellPrompt()
		if not prompt then return false end
		local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
		if not hrp or (hrp.Position - prompt.Parent.Position).Magnitude > prompt.MaxActivationDistance then return false end
		if fireproximityprompt then
			fireproximityprompt(prompt)
		else
			prompt:InputHoldBegin()
			task.wait(prompt.HoldDuration + 0.15)
			prompt:InputHoldEnd()
		end
		return true
	end
	local function sellAllFish()
		local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
		if not hum then return end
		local soldAny = false
		while countFish() > 0 do
			stowTools()
			task.wait(0.15)
			local fish = getNextFish()
			if not fish or not fish.Parent then break end
			_G.AutoFishMode = "Selling: " .. fish.Name
			hum:EquipTool(fish)
			task.wait(0.3)
			sellHeldFish()
			soldAny = true
			task.wait(SELL_DELAY)
		end
		stowTools()
		if soldAny then _G.AutoFishStats.sells += 1 end
	end
	local function returnToDock()
		if not _G.AutoFishEnabled or _G.AutoFishReturnOnDeath == false then return end
		if _G.AutoFishCeremony then return end
		_G.AutoFishReturnToken += 1
		local token = _G.AutoFishReturnToken
		task.spawn(function()
			local char = LocalPlayer.Character
			if not char then return end
			local hum = char:FindFirstChildOfClass("Humanoid")
			local hrp = char:FindFirstChild("HumanoidRootPart")
			if not hum or not hrp then return end
			if token ~= _G.AutoFishReturnToken then return end
			_G.AutoFishReturning = true
			_G.AutoFishBusy = true
			stowTools()
			_G.AutoFishMode = "Returning to dock"
			local function stillReturning()
				return token == _G.AutoFishReturnToken and not _G.AutoFishCeremony
			end
			walkTo(getDockPos(), 120, stillReturning)
			if token ~= _G.AutoFishReturnToken then return end
			char = LocalPlayer.Character
			hum = char and char:FindFirstChildOfClass("Humanoid")
			if not hum or hum.Health <= 0 then return end
			if not stillReturning() then
				if not _G.AutoFishCeremony then
					_G.AutoFishReturning = false
					_G.AutoFishBusy = false
				end
				return
			end
			faceLook(getDockLook())
			if token ~= _G.AutoFishReturnToken then return end
			char = LocalPlayer.Character
			hum = char and char:FindFirstChildOfClass("Humanoid")
			if not hum or hum.Health <= 0 then return end
			_G.AutoFishReturning = false
			_G.AutoFishBusy = false
			_G.AutoFishMode = "Fishing"
		end)
	end
	local function pulseServerNotAfk()
		if not _G.AutoFishAntiAfk or not _G.AutoFishAfkRemoting then return end
		pcall(function()
			_G.AutoFishAfkRemoting:FireServer("IMightBeAFK", false)
		end)
	end
	local function blockActivityControllerAfk()
		if not getconnections then return end
		for _, conn in ipairs(getconnections(UserInputService.WindowFocusReleased)) do
			local fn = conn.Function
			if typeof(fn) == "function" and debug and debug.info then
				local ok, src = pcall(debug.info, fn, "s")
				if ok and src and tostring(src):find("ActivityController") then
					pcall(function() conn:Disable() end)
				end
			end
		end
	end
	local function hookAfkRemote(afkEvent)
		if not afkEvent or not hookfunction or _G.AutoFishAfkRemoteHook then return end
		local oldFire = afkEvent.FireServer
		local function wrapped(...)
			if _G.AutoFishAntiAfk ~= false then
				local args = { ... }
				local afkArg = args[1]
				if typeof(afkArg) == "Instance" then
					afkArg = args[2]
				end
				if afkArg == true then
					if typeof(args[1]) == "Instance" then
						return oldFire(args[1], false)
					end
					return oldFire(false)
				end
			end
			return oldFire(...)
		end
		if newcclosure then
			wrapped = newcclosure(wrapped)
		end
		_G.AutoFishAfkRemoteHook = hookfunction(oldFire, wrapped)
	end
	local function setupServerAntiAfk()
		local packages = game:GetService("ReplicatedStorage"):FindFirstChild("Packages")
		local remotingModule = packages and packages:FindFirstChild("Remoting")
		if remotingModule then
			local ok, Remoting = pcall(require, remotingModule)
			if ok then
				_G.AutoFishAfkRemoting = Remoting.new(LocalPlayer, "Player")
			end
		end

		local playerRemotes = LocalPlayer:WaitForChild("PlayerRemotes", 30)
		local afkEvent = playerRemotes and playerRemotes:WaitForChild("IMightBeAFKEvent", 30)
		hookAfkRemote(afkEvent)
		blockActivityControllerAfk()

		if _G.AutoFishAfkPulseConnection then
			pcall(function() _G.AutoFishAfkPulseConnection:Disconnect() end)
		end
		local lastPulse = 0
		_G.AutoFishAfkPulseConnection = RunService.Heartbeat:Connect(function()
			if not _G.AutoFishAntiAfk then return end
			local now = tick()
			if now - lastPulse < 4 then return end
			lastPulse = now
			pulseServerNotAfk()
		end)

		if _G.AutoFishAfkAttrConnection then
			pcall(function() _G.AutoFishAfkAttrConnection:Disconnect() end)
		end
		_G.AutoFishAfkAttrConnection = LocalPlayer:GetAttributeChangedSignal("AFK"):Connect(function()
			if LocalPlayer:GetAttribute("AFK") == true then
				pulseServerNotAfk()
			end
		end)

		if _G.AutoFishIdledConnection then
			pcall(function() _G.AutoFishIdledConnection:Disconnect() end)
		end
		_G.AutoFishIdledConnection = LocalPlayer.Idled:Connect(function()
			if not _G.AutoFishAntiAfk then return end
			VirtualUser:CaptureController()
			VirtualUser:ClickButton2(Vector2.new())
			pulseServerNotAfk()
		end)

		pulseServerNotAfk()
	end

	local function formatWaitTime(seconds)
		seconds = math.max(0, math.ceil(seconds))
		return string.format("%d:%02d", math.floor(seconds / 60), seconds % 60)
	end
