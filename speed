-- Auto Fish v8.4 — IY-style queue_on_teleport + HttpGet rejoin
local AUTOFISH_CONFIG_DIR = "AutoFish"
local AUTOFISH_STATE_FILE = AUTOFISH_CONFIG_DIR .. "/state.json"

local queueTeleport = queue_on_teleport
	or (syn and syn.queue_on_teleport)
	or (fluxus and fluxus.queue_on_teleport)

local function vec3Enc(v)
	if not v then return nil end
	return { X = v.X, Y = v.Y, Z = v.Z }
end
local function vec3Dec(t)
	if not t then return nil end
	return Vector3.new(t.X, t.Y, t.Z)
end
local function spotEnc(spot)
	if not spot then return nil end
	return {
		position = vec3Enc(spot.position),
		lookVector = vec3Enc(spot.lookVector),
		setAt = spot.setAt,
	}
end
local function spotDec(t)
	if not t then return nil end
	return {
		position = vec3Dec(t.position),
		lookVector = vec3Dec(t.lookVector),
		setAt = t.setAt,
	}
end

local AUTOFISH_SCRIPT_URL = "https://raw.githubusercontent.com/temptular/kaicenat/refs/heads/main/speed"

local function getAutoFishScriptUrl()
	if getgenv and getgenv().AutoFishScriptUrl then
		return getgenv().AutoFishScriptUrl
	end
	if _G.AutoFishScriptUrl then
		return _G.AutoFishScriptUrl
	end
	return AUTOFISH_SCRIPT_URL
end

local function getQueueTeleportScript()
	local url = getAutoFishScriptUrl()
	if not url then return nil end
	return ("loadstring(game:HttpGet(%q))()"):format(url)
end

_G.AutoFishPersistState = function(pendingReturn)
	if not writefile then return false end
	pcall(function()
		if isfolder and not isfolder(AUTOFISH_CONFIG_DIR) then
			makefolder(AUTOFISH_CONFIG_DIR)
		end
	end)
	local HttpService = game:GetService("HttpService")
	local state = {
		dock = spotEnc(_G.AutoFishDockSpot),
		cast = spotEnc(_G.AutoFishCastSpot),
		flag = spotEnc(_G.AutoFishFlagSpot),
		enabled = _G.AutoFishEnabled,
		returnOnDeath = _G.AutoFishReturnOnDeath,
		antiAfk = _G.AutoFishAntiAfk,
		keepOnTeleport = _G.AutoFishKeepOnTeleport ~= false,
		pendingReturn = pendingReturn == true,
		scriptUrl = getAutoFishScriptUrl(),
	}
	local ok = pcall(function()
		writefile(AUTOFISH_STATE_FILE, HttpService:JSONEncode(state))
	end)
	return ok
end

local function loadAutoFishState()
	if not readfile or not isfile or not isfile(AUTOFISH_STATE_FILE) then return end
	local HttpService = game:GetService("HttpService")
	local ok, data = pcall(function()
		return HttpService:JSONDecode(readfile(AUTOFISH_STATE_FILE))
	end)
	if not ok or type(data) ~= "table" then return end
	if data.dock then _G.AutoFishDockSpot = spotDec(data.dock) end
	if data.cast then _G.AutoFishCastSpot = spotDec(data.cast) end
	if data.flag then _G.AutoFishFlagSpot = spotDec(data.flag) end
	if data.enabled ~= nil then _G.AutoFishEnabled = data.enabled end
	if data.returnOnDeath ~= nil then _G.AutoFishReturnOnDeath = data.returnOnDeath end
	if data.antiAfk ~= nil then _G.AutoFishAntiAfk = data.antiAfk end
	if data.keepOnTeleport ~= nil then _G.AutoFishKeepOnTeleport = data.keepOnTeleport ~= false end
	if data.pendingReturn then _G.AutoFishPendingReturn = true end
	if data.scriptUrl then
		_G.AutoFishScriptUrl = data.scriptUrl
		if getgenv then getgenv().AutoFishScriptUrl = data.scriptUrl end
	end
end

local function queueAutoFishOnTeleport()
	if not queueTeleport then return false end
	local script = getQueueTeleportScript()
	if not script then
		warn("[AutoFish] Set getgenv().AutoFishScriptUrl to a raw script URL (GitHub raw, etc.)")
		return false
	end
	queueTeleport(script)
	return true
end

_G.AutoFishRejoin = function(pendingReturn)
	if _G.AutoFishRejoining then return end
	_G.AutoFishRejoining = true
	pendingReturn = pendingReturn ~= false
	_G.AutoFishPendingReturn = pendingReturn
	_G.AutoFishPersistState(pendingReturn)
	queueAutoFishOnTeleport()
	local Players = game:GetService("Players")
	local TeleportService = game:GetService("TeleportService")
	local LocalPlayer = Players.LocalPlayer
	local placeId = game.PlaceId
	if #Players:GetPlayers() <= 1 then
		LocalPlayer:Kick("\nAutoFish rejoining...")
		task.wait()
		TeleportService:Teleport(placeId, LocalPlayer)
	else
		TeleportService:TeleportToPlaceInstance(placeId, game.JobId, LocalPlayer)
	end
end

if not _G.AutoFishTeleportHooked then
	_G.AutoFishTeleportHooked = true
	local Players = game:GetService("Players")
	local LocalPlayer = Players.LocalPlayer
	local teleportCheck = false
	LocalPlayer.OnTeleport:Connect(function()
		if _G.AutoFishKeepOnTeleport == false then return end
		if teleportCheck or not queueTeleport then return end
		teleportCheck = true
		_G.AutoFishPersistState(_G.AutoFishPendingReturn == true)
		queueAutoFishOnTeleport()
	end)
end

